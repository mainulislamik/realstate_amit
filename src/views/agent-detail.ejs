<%- include('partials/header') %>

<section class="page-header">
  <div class="container">
    <h1><%= agent.name %></h1>
    <p><%= agent.title %></p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="founder" style="margin-bottom:56px;">
      <div class="team-photo" style="width:200px;height:200px;margin:0;">
        <img src="<%= agent.image %>" alt="<%= agent.name %>">
      </div>
      <div class="founder-text">
        <h2 style="font-size:1.8rem;"><%= agent.name %></h2>
        <% if (agent.verified) { %><div class="verified"><i class="fas fa-check-circle"></i> Verified Agent</div><% } %>
        <p><%= agent.bio %></p>
        <div class="founder-info" style="margin:18px 0;">
          <p><i class="fas fa-phone"></i> <a href="tel:<%= agent.phone.replace(/\s/g,'') %>"><%= agent.phone %></a></p>
          <p><i class="fas fa-phone"></i> <a href="tel:<%= agent.phone2.replace(/\s/g,'') %>"><%= agent.phone2 %></a></p>
          <p><i class="fas fa-envelope"></i> <a href="mailto:<%= agent.email %>"><%= agent.email %></a></p>
        </div>
        <a href="https://wa.me/<%= agent.whatsapp %>" class="btn-primary"><i class="fab fa-whatsapp"></i> Message on WhatsApp</a>
      </div>
    </div>

    <% if (properties.length > 0) { %>
      <div class="section-head" style="text-align:left;margin-bottom:32px;">
        <h2 style="font-size:1.6rem;">Listings by <%= agent.name %></h2>
      </div>
      <div class="property-grid">
        <% properties.forEach(p => { %>
          <article class="property-card reveal">
            <div class="property-image">
              <img src="<%= p.image %>" alt="<%= p.title %>" loading="lazy">
              <div class="property-badges"><span class="badge badge-status"><%= p.status %></span></div>
            </div>
            <div class="property-info">
              <h3><a href="/properties/<%= p.slug %>"><%= p.title %></a></h3>
              <div class="price">$<%= p.price.toLocaleString() %></div>
              <div class="property-type"><%= p.type %></div>
              <div class="property-meta">
                <% if (p.beds > 0) { %><span><i class="fas fa-bed"></i> <%= p.beds %> Beds</span><% } %>
                <span><i class="fas fa-bath"></i> <%= p.baths %> Baths</span>
                <span><i class="fas fa-vector-square"></i> <%= p.sqft.toLocaleString() %> sqft</span>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
