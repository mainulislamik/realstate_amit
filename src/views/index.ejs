<%- include('partials/header') %>

<section class="hero">
  <span class="hero-shape s1"></span>
  <span class="hero-shape s2"></span>
  <span class="hero-shape s3"></span>
  <div class="hero-content">
    <div class="container">
      <h1>Discover Your Next Home,<br>Where Comfort Meets Lifestyle</h1>
      <p class="hero-sub">Browse thousands of verified listings and connect with local experts who put your needs first.</p>
      <div class="search-card reveal">
        <form action="/properties" method="get">
          <div class="search-tabs">
            <button type="button" class="tab active" data-value="any">All Status</button>
            <button type="button" class="tab" data-value="for sale">For Buy</button>
            <button type="button" class="tab" data-value="for rent">For Rent</button>
            <button type="button" class="tab" data-value="for sale">For Sale</button>
          </div>
          <div class="search-fields">
            <div class="field">
              <label>Property Type</label>
              <select name="type">
                <option value="any">Any Type</option>
                <% propertyTypes.forEach(t => { %><option value="<%= t.name.toLowerCase() %>"><%= t.name %></option><% }) %>
              </select>
            </div>
            <div class="field">
              <label>Location</label>
              <select name="location">
                <option value="any">All Cities</option>
                <% [...new Set(featured.map(p => p.location))].sort().forEach(loc => { %><option value="<%= loc %>"><%= loc %></option><% }) %>
              </select>
            </div>
            <div class="field">
              <label>Min Price</label>
              <select name="minPrice">
                <option value="">No Min</option>
                <option value="5000">$5,000</option><option value="50000">$50,000</option>
                <option value="100000">$100,000</option><option value="500000">$500,000</option>
                <option value="1000000">$1,000,000</option><option value="5000000">$5,000,000</option>
              </select>
            </div>
            <div class="field">
              <label>Max Price</label>
              <select name="maxPrice">
                <option value="">No Max</option>
                <option value="100000">$100,000</option><option value="500000">$500,000</option>
                <option value="1000000">$1,000,000</option><option value="2000000">$2,000,000</option>
                <option value="5000000">$5,000,000</option><option value="10000000">$10,000,000</option>
              </select>
            </div>
            <button type="submit" class="btn-search"><i class="fas fa-search"></i> Search</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<section class="section" style="padding-top:64px;">
  <div class="container">
    <div class="type-pills reveal">
      <% propertyTypes.forEach(t => { %>
        <a href="/properties?type=<%= t.name.toLowerCase() %>" class="type-pill"><i class="fas fa-building"></i> <%= t.name %></a>
      <% }) %>
    </div>
  </div>
</section>

<section class="section" style="padding-top:24px;">
  <div class="container">
    <div class="marquee reveal">
      <div class="marquee-track">
        <span class="marquee-item">🏠 Premium Homes</span>
        <span class="marquee-item">🌆 Luxury Condos</span>
        <span class="marquee-item">🏖️ Beachfront Villas</span>
        <span class="marquee-item">🏢 Commercial Spaces</span>
        <span class="marquee-item">🌳 Land & Plots</span>
        <span class="marquee-item">🏘️ Townhouses</span>
        <span class="marquee-item">🏙️ Penthouses</span>
        <span class="marquee-item">🛋️ Cozy Studios</span>
        <span class="marquee-item">🏠 Premium Homes</span>
        <span class="marquee-item">🌆 Luxury Condos</span>
        <span class="marquee-item">🏖️ Beachfront Villas</span>
        <span class="marquee-item">🏢 Commercial Spaces</span>
        <span class="marquee-item">🌳 Land & Plots</span>
        <span class="marquee-item">🏘️ Townhouses</span>
        <span class="marquee-item">🏙️ Penthouses</span>
        <span class="marquee-item">🛋️ Cozy Studios</span>
      </div>
    </div>
  </div>
</section>

<section class="section" style="padding-top:24px;">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Featured</span>
      <h2>Featured Properties: Your Next Great Find</h2>
      <p>Hand-picked homes, villas and investments chosen by our local experts.</p>
    </div>
      <div class="property-grid">
      <% featured.forEach(p => { %>
        <article class="property-card reveal" data-tilt>
          <div class="property-image">
            <img src="<%= p.image %>" alt="<%= p.title %>" loading="lazy">
            <div class="property-badges">
              <span class="badge badge-status"><%= p.status %></span>
              <% if (p.label) { %><span class="badge badge-label"><%= p.label %></span><% } %>
            </div>
            <div class="property-fav"><i class="far fa-heart"></i></div>
            <div class="property-overlay"><a href="/properties/<%= p.slug %>" class="view-btn">View Details <i class="fas fa-arrow-right"></i></a></div>
          </div>
          <div class="property-info">
            <h3><a href="/properties/<%= p.slug %>"><%= p.title %></a></h3>
            <div class="price">$<%= p.price.toLocaleString() %></div>
            <div class="property-type"><%= p.type %></div>
            <div class="property-meta">
              <% if (p.beds > 0) { %><span><i class="fas fa-bed"></i> <%= p.beds %> Beds</span><% } %>
              <span><i class="fas fa-bath"></i> <%= p.baths %> Baths</span>
              <span><i class="fas fa-vector-square"></i> <%= p.sqft.toLocaleString() %> sqft</span>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
    <div style="text-align:center;margin-top:48px;">
      <a href="/properties" class="btn-outline">View All Listings <i class="fas fa-arrow-right"></i></a>
    </div>
  </div>
</section>

<section class="section section-alt">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">What We Do</span>
      <h2>Your Local Experts in Real Estate Excellence</h2>
      <p>From the first consultation to the final signature, our team delivers a seamless, tailored experience.</p>
    </div>
    <div class="services-grid">
      <div class="service-card reveal"><div class="service-icon"><i class="fas fa-chart-line"></i></div><h3>Strategic Home Marketing</h3><p>Tailored campaigns to attract the right buyers and maximize visibility.</p></div>
      <div class="service-card reveal"><div class="service-icon"><i class="fas fa-user-check"></i></div><h3>Buyer Guidance</h3><p>Expert advice and market insights from tours through closing.</p></div>
      <div class="service-card reveal"><div class="service-icon"><i class="fas fa-home"></i></div><h3>Accurate Valuations</h3><p>Data-backed estimates so you can make informed decisions.</p></div>
      <div class="service-card reveal"><div class="service-icon"><i class="fas fa-truck-moving"></i></div><h3>Relocation Support</h3><p>We coordinate every detail and connect you with local resources.</p></div>
      <div class="service-card reveal"><div class="service-icon"><i class="fas fa-map-marked-alt"></i></div><h3>Neighborhood Expertise</h3><p>Find the right fit based on lifestyle, schools and budget.</p></div>
      <div class="service-card reveal"><div class="service-icon"><i class="fas fa-handshake"></i></div><h3>Negotiation & Closing</h3><p>We negotiate on your behalf and manage all the paperwork.</p></div>
      <div class="service-card reveal"><div class="service-icon"><i class="fas fa-chart-pie"></i></div><h3>Rental & Investment</h3><p>Spot high-potential opportunities and manage the process end to end.</p></div>
      <div class="service-card reveal"><div class="service-icon"><i class="fas fa-headset"></i></div><h3>Ongoing Support</h3><p>Our relationship doesn't end at the sale — we're always here.</p></div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="founder reveal">
      <div class="founder-text">
        <span class="eyebrow">About Us</span>
        <h2>We Know the Market. We Know What Matters.</h2>
        <p>Helping buyers, sellers, and investors navigate the real estate market with confidence. Through local expertise, honest guidance, and personalized service, we make every transaction smooth, transparent, and successful.</p>
        <div class="founder-info">
          <h3>Indrojit Sarker</h3>
          <p>Licensed Real Estate Broker | Founder, Express Realty Prime</p>
        </div>
        <a href="/contact" class="btn-primary">Get a Free Home Valuation</a>
      </div>
      <div class="stats-card">
        <div class="stat"><span class="stat-num count-num" data-count="<%= stats.years %>"><%= stats.years %></span><span class="stat-label">Years of experience</span></div>
        <div class="stat"><span class="stat-num count-num" data-count="<%= stats.sold %>"><%= stats.sold %></span><span class="stat-label">Properties sold</span></div>
        <div class="stat"><span class="stat-num count-num" data-count="<%= stats.partners %>"><%= stats.partners %></span><span class="stat-label">Affiliate partners</span></div>
        <div class="stat"><span class="stat-num count-num" data-count="<%= stats.profits %>" data-suffix="%"><%= stats.profits %>%</span><span class="stat-label">Year Profits</span></div>
      </div>
    </div>
  </div>
</section>

<section class="section section-alt">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Browse</span>
      <h2>Explore Property Types That Fit Your Lifestyle</h2>
    </div>
    <div class="cat-grid">
      <% propertyTypes.forEach(t => { %>
        <a href="/properties?type=<%= t.name.toLowerCase() %>" class="cat-card reveal">
          <div class="cat-icon"><i class="fas fa-building"></i></div>
          <h3><%= t.name %></h3>
          <span><%= t.count %> Properties</span>
        </a>
      <% }) %>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Our Team</span>
      <h2>Meet Our Team of Local Experts</h2>
    </div>
    <div class="team-grid">
      <% agents.forEach(agent => { %>
        <div class="team-card reveal">
          <div class="team-photo"><img src="<%= agent.image %>" alt="<%= agent.name %>" loading="lazy"></div>
          <div class="team-info">
            <h3><a href="/agents/<%= agent.slug %>"><%= agent.name %></a></h3>
            <div class="role"><%= agent.title %></div>
            <% if (agent.verified) { %><div class="verified"><i class="fas fa-check-circle"></i> Verified</div><% } %>
            <div class="team-contacts">
              <a href="tel:<%= agent.phone.replace(/\s/g,'') %>"><i class="fas fa-phone"></i> <%= agent.phone %></a>
              <a href="tel:<%= agent.phone2.replace(/\s/g,'') %>"><%= agent.phone2 %></a>
            </div>
            <a href="https://wa.me/<%= agent.whatsapp %>" class="wa-link"><i class="fab fa-whatsapp"></i> Contact on WhatsApp</a>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<section class="section section-alt">
  <div class="container">
    <div class="cta reveal">
      <h2>Know What Your Home Is Worth Today</h2>
      <p>Thinking about selling or just curious? Get a professional, no-obligation valuation backed by real market insights — fast, accurate, and 100% free.</p>
      <a href="/contact" class="btn-primary btn-lg">Get a Free Home Valuation</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
