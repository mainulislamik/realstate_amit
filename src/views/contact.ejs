<%- include('partials/header') %>

<section class="page-header">
  <div class="container">
    <h1>Contact Us</h1>
    <p>We'd love to hear from you</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info reveal">
        <h2>Get in Touch</h2>
        <div class="info-item"><i class="fas fa-phone"></i> <a href="tel:9876543210">(987) 654 3210</a></div>
        <div class="info-item"><i class="fas fa-envelope"></i> <a href="mailto:info@expressrealtyprime.com">info@expressrealtyprime.com</a></div>
        <div class="info-item"><i class="fas fa-map-marker-alt"></i> New York, NY</div>
        <div class="contact-hours">
          <h3>Office Hours</h3>
          <p>Mon - Fri: 9:00 AM - 6:00 PM</p>
          <p>Saturday: 10:00 AM - 4:00 PM</p>
          <p>Sunday: Closed</p>
        </div>
      </div>
      <div class="contact-form reveal">
        <% if (message) { %><div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= message %></div><% } %>
        <form action="/contact" method="post">
          <div class="form-group">
            <label for="name">Full Name</label>
            <input type="text" id="name" name="name" placeholder="Jane Doe" required>
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="jane@example.com" required>
          </div>
          <div class="form-group">
            <label for="phone">Phone</label>
            <input type="tel" id="phone" name="phone" placeholder="(987) 654 3210">
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" placeholder="How can we help?" required></textarea>
          </div>
          <button type="submit" class="btn-primary btn-block">Send Message</button>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
