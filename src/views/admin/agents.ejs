<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin">
  <div class="admin-layout">
    <%- include('sidebar', { active: 'agents', username: '' }) %>
    <div class="admin-main">
      <div class="admin-topbar">
        <h1>Agents</h1>
        <a href="/admin/agents/new" class="btn btn-primary"><i class="fas fa-plus"></i> Add Agent</a>
      </div>
      <div class="admin-content">
        <div class="panel">
          <div class="panel-body" style="padding:0;">
            <table class="admin-table">
              <thead>
                <tr><th>Photo</th><th>Name</th><th>Title</th><th>Email</th><th>Verified</th><th>Actions</th></tr>
              </thead>
              <tbody>
                <% agents.forEach(a => { %>
                  <tr>
                    <td><img src="<%= a.image %>" alt="" class="thumb-sm" style="width:44px;height:44px;border-radius:50%;"></td>
                    <td class="row-title"><%= a.name %></td>
                    <td><%= a.title %></td>
                    <td><%= a.email %></td>
                    <td><%= a.verified ? '<span class="tag tag-green">Verified</span>' : '—' %></td>
                    <td>
                      <div class="actions">
                        <a href="/admin/agents/<%= a.id %>/edit" class="btn btn-ghost btn-sm"><i class="fas fa-edit"></i></a>
                        <form action="/admin/agents/<%= a.id %>/delete" method="post" onsubmit="return confirm('Delete this agent?');">
                          <button class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
