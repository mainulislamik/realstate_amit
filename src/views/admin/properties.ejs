<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin">
  <div class="admin-layout">
    <%- include('sidebar', { active: 'properties', username: '' }) %>
    <div class="admin-main">
      <div class="admin-topbar">
        <h1>Properties</h1>
        <a href="/admin/properties/new" class="btn btn-primary"><i class="fas fa-plus"></i> Add Property</a>
      </div>
      <div class="admin-content">
        <div class="panel">
          <div class="panel-body" style="padding:0;">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Image</th><th>Title</th><th>Type</th><th>Status</th><th>Price</th><th>Featured</th><th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% properties.forEach(p => { %>
                  <tr>
                    <td><img src="<%= p.image %>" alt="" class="thumb-sm"></td>
                    <td class="row-title"><%= p.title %></td>
                    <td><span class="tag tag-gray"><%= p.type %></span></td>
                    <td><span class="tag <%= p.status === 'For Sale' ? 'tag-green' : 'tag-blue' %>"><%= p.status %></span></td>
                    <td>$<%= p.price.toLocaleString() %></td>
                    <td><%= p.featured ? '✅' : '—' %></td>
                    <td>
                      <div class="actions">
                        <a href="/admin/properties/<%= p.id %>/edit" class="btn btn-ghost btn-sm"><i class="fas fa-edit"></i></a>
                        <form action="/admin/properties/<%= p.id %>/delete" method="post" onsubmit="return confirm('Delete this property?');">
                          <button class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
