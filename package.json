{
  "name": "express-realty-prime",
  "version": "2.0.0",
  "description": "Express Realty Prime - Real Estate Website with Admin Panel (NestJS + TypeORM + PostgreSQL)",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && npx copyfiles -u 1 \"src/views/**/*\" dist/ && npx copyfiles -u 1 \"src/public/**/*\" dist/",
    "start": "node dist/main.js",
    "dev": "ts-node-dev --respawn src/main.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/typeorm": "^10.0.2",
    "bcryptjs": "^2.4.3",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-session": "^1.18.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "copyfiles": "^2.4.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
